# Cloudflare Pages – HTTP response headers
# ==========================================
# Service worker MUST be served with no-store so browsers always fetch the latest
# bytes. If sw.js is HTTP-cached, browsers never detect file changes and the old
# service worker keeps running indefinitely (including inside the APK WebView).
/sw.js
  Cache-Control: no-store, no-cache, must-revalidate, proxy-revalidate
  Pragma: no-cache
  Expires: 0

# index.html must also be no-cache so the entry point is always fresh.
# Vite hashes all JS/CSS chunks, so only index.html needs this treatment.
/index.html
  Cache-Control: no-store, no-cache, must-revalidate, proxy-revalidate
  Pragma: no-cache
  Expires: 0

# Same for the web manifest (controls PWA install metadata).
/manifest.webmanifest
  Cache-Control: no-store, no-cache, must-revalidate, proxy-revalidate

# Hashed Vite assets are immutable – max cache, browser re-fetches only when hash changes.
/assets/*
  Cache-Control: public, max-age=31536000, immutable
